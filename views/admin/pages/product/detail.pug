extends ../../layouts/default.pug

block main

    if roleUser.permissions.includes('products_view')
        if product
            h1.mb-4 #{product.title}

            .card.mb-3
                .card-header Thông tin sản phẩm
                .card-body
                    .row
                        .col-md-4
                            img.img-fluid(
                                src=product.thumbnail
                                alt=product.title
                            )

                        .col-md-8
                            h3 #{product.price.toLocaleString('vi-VN')} VND

                            p Giảm giá: #{product.discountPercentage}%
                            p Còn lại: #{product.stock}

                            p Trạng thái:
                                if product.status === 'active'
                                    span.badge.bg-success.ms-2 Hoạt động
                                else if product.status === 'inactive'
                                    span.badge.bg-danger.ms-2 Dừng hoạt động

                            p Danh mục: #{product.nameCategory}
                            p Vị trí: #{product.position}

                            p !{product.description}

                            a.btn.btn-warning(
                                href=`${prefixAdmin}/products/edit/${product._id}`
                            ) Chỉnh sửa sản phẩm
        else
            h1.mb-4 Sản phẩm không tồn tại

        script(src="/admin/js/product.js")
    else
        +alert-no-permission()
